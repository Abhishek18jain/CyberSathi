# MP Online Hub – Backend Environment Variables
# Copy this file to .env and fill in your real values

PORT=5000

# ── Cloudinary ────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── remove.bg ─────────────────────────────────────
# Sign up at https://www.remove.bg/api and get a free key (50 API calls/month free)
# Used by: Passport Photo Generator → "Remove Background" toggle
REMOVE_BG_API_KEY=your_remove_bg_api_key
